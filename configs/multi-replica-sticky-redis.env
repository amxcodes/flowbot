# Multi-replica sticky production baseline
NANOBOT_REPLICA_COUNT=2
NANOBOT_SCALING_MODE=sticky
NANOBOT_STICKY_SIGNAL_HEADER=x-session-affinity

# Redis distributed state
NANOBOT_DISTRIBUTED_STORE_BACKEND=redis
NANOBOT_REDIS_URL=redis://127.0.0.1:6379/
NANOBOT_REDIS_KEY_PREFIX=nanobot-prod

# Global provider limiter (required for multi-replica)
NANOBOT_GLOBAL_PROVIDER_QPS_LIMIT=20
NANOBOT_PROVIDER_LIMITER_BACKEND=redis
NANOBOT_PROVIDER_LIMITER_FAILURE_MODE=closed
NANOBOT_PROVIDER_LIMITER_REDIS_TIMEOUT_MS=150

# Multi-replica startup readiness
NANOBOT_REDIS_STARTUP_TIMEOUT_MS=300
NANOBOT_REDIS_STARTUP_RETRY_COUNT=1
