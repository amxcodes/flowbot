# Single-replica baseline
NANOBOT_REPLICA_COUNT=1
NANOBOT_SCALING_MODE=sticky

# Optional but recommended for parity with multi-replica
NANOBOT_DISTRIBUTED_STORE_BACKEND=redis
NANOBOT_REDIS_URL=redis://127.0.0.1:6379/

# Provider limiter can be local/open in single node
NANOBOT_GLOBAL_PROVIDER_QPS_LIMIT=20
NANOBOT_PROVIDER_LIMITER_BACKEND=local
NANOBOT_PROVIDER_LIMITER_FAILURE_MODE=open

# Startup redis readiness controls (used when redis-backed paths enabled)
NANOBOT_REDIS_STARTUP_TIMEOUT_MS=300
NANOBOT_REDIS_STARTUP_RETRY_COUNT=0
