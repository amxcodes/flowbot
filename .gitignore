# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-guide-s-guide.html#cargo-lock
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Environment variables
.env
config.toml

# Local runtime state / secrets
.nanobot/
crates/nanobot-core/.nanobot/

# VS Code settings
.vscode/

# Brain/Artifacts
brain/
artifacts/

# System generated logs
.system_generated/

# Runtime caches/artifacts
.fastembed_cache/
crates/nanobot-core/.fastembed_cache/
workspace/skills/*/node_modules/
workspace/skills/*/package-lock.json

# Local logs and one-off outputs
build_errors.txt
build_log.txt
check_output.txt
test_errors.txt
test_errors_2.txt
test_run_output.txt
