# ========================================
# Nanobot Environment Configuration
# ========================================

# REQUIRED: Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# RECOMMENDED: Comma-separated list of allowed Telegram user IDs
# Get your ID from @userinfobot
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ========================================
# Provider Authentication (choose one)
# ========================================

# Option 1: Antigravity OAuth (RECOMMENDED for production)
# Run: nanobot-rs login antigravity
# Tokens stored in ~/.antigravity/tokens.json

# Option 2: Antigravity API Key (for testing)
# Get from: https://makersuite.google.com/app/apikey
# ANTIGRAVITY_API_KEY=AIza...

# Option 3: OpenRouter API Key
# Get from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Option 4: OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# ========================================
# Optional: Google OAuth Credentials
# ========================================
# Only needed if using Antigravity OAuth
# Get from: https://console.cloud.google.com/apis/credentials

# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret

# Optional: inbound webhook auth
# Shared token gate (interim): x-nanobot-webhook-token
# NANOBOT_TEAMS_WEBHOOK_SECRET=replace_me
# NANOBOT_GOOGLE_CHAT_WEBHOOK_SECRET=replace_me
#
# Signed mode (recommended): HMAC-SHA256 over "<timestamp>.<nonce>.<raw_body>"
# Headers: x-nanobot-signature, x-nanobot-timestamp, x-nanobot-nonce
# NANOBOT_TEAMS_WEBHOOK_SIGNING_SECRET=replace_me
# NANOBOT_GOOGLE_CHAT_WEBHOOK_SIGNING_SECRET=replace_me
# NANOBOT_WEBHOOK_MAX_SKEW_SECONDS=300
# Optional shared nonce store path for multi-instance replay defense
# NANOBOT_WEBHOOK_NONCE_DB_PATH=.nanobot/webhook_nonces.db

# Metrics endpoint policy
# In production, /metrics requires auth unless this is enabled
# NANOBOT_METRICS_PUBLIC=false

# UNSAFE production bypass for antigravity hardcoded credentials path (not recommended)
# BOTH variables are required in production to enable this override:
# NANOBOT_ALLOW_UNSAFE_ANTIGRAVITY=1
# NANOBOT_ALLOW_UNSAFE_ANTIGRAVITY_CONFIRM=I_UNDERSTAND_THIS_IS_INSECURE
# Optional temporary TTL guard (minutes + issued-at epoch seconds)
# NANOBOT_UNSAFE_OVERRIDE_TTL_MIN=60
# NANOBOT_UNSAFE_OVERRIDE_ISSUED_AT_EPOCH=1739744000

# ========================================
# Optional: Logging
# ========================================
# RUST_LOG=info      # Options: error, warn, info, debug, trace
